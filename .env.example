# ============================================================
# BANCO DE DADOS (obrigatório)
# Recomendado: Neon (neon.tech) ou Vercel Postgres
# Formato: postgresql://user:password@host:5432/dbname?sslmode=require
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/afiliadu"

# ============================================================
# NEXTAUTH (obrigatório)
# AUTH_SECRET: gere com: openssl rand -base64 32
# NEXTAUTH_URL: URL pública do deploy (no Vercel é auto-detectado)
# ============================================================
AUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="afiliadu.com"

# ============================================================
# OPCIONAL — Redis (para filas de clonagem avançada, Fase 2)
# ============================================================
# REDIS_URL="redis://localhost:6379"
